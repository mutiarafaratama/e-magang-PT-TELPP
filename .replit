modules = ["nodejs-20", "vue-node-20", "go-1.21", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Go API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IzinSakit API Server"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/frontend run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Go API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && ./bin/server"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "IzinSakit API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18130
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8080"
APP_ENV = "development"
JWT_EXPIRY = "24h"
REFRESH_EXPIRY = "168h"
UPLOAD_DIR = "./uploads"
MAX_UPLOAD_SIZE = "10485760"
JWT_SECRET = "54ff827ea308d541f37c121c78b495cbb03148c4bb315fbd9e1df99399ec5d38fef9995bc660ae209fb8f95f35fafcf4"
RESEND_FROM_EMAIL = "e-Magang TELPP <noreply@aideacreative.my.id>"

[userenv.development]
